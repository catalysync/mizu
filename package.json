{
  "name": "mizu",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "turbo run typecheck",
    "doctor": "npx -y react-doctor@latest . -y",
    "doctor:diff": "npx -y react-doctor@latest . -y --diff main",
    "doctor:score": "npx -y react-doctor@latest . -y --score",
    "doctor:gate": "node scripts/doctor-gate.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@commitlint/cli": "^19.7.1",
    "@eslint/js": "^9.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-ssr-friendly": "^1.3.0",
    "eslint-plugin-testing-library": "^7.16.2",
    "globals": "^15.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.7.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "turbo": "^2.9.4",
    "typescript": "5.9.2",
    "typescript-eslint": "^8.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=22"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,css,json,md,mdx}": "prettier --write"
  }
}
