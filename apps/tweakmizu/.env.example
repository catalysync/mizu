# ---------- Database ----------
# Neon Postgres connection string. Required for auth, subscriptions, saved projects.
# Easiest path: `neonctl projects create --name tweakmizu` then copy the pooled URL.
DATABASE_URL=

# ---------- Better Auth ----------
# The app's public base URL. In local dev, http://localhost:3000. In prod, https://tweakmizu.vercel.app.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# OAuth providers (better-auth socialProviders)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---------- Polar (subscriptions) ----------
# Get from the Polar dashboard (organization → API tokens)
POLAR_ACCESS_TOKEN=

# Webhook secret from the Polar webhook endpoint config
POLAR_WEBHOOK_SECRET=

# Product id for the tweakmizu Pro subscription
NEXT_PUBLIC_TWEAKMIZU_PRO_PRODUCT_ID=

# ---------- Anthropic (studio composer) ----------
# Server-side only. Never expose to the client.
ANTHROPIC_API_KEY=
