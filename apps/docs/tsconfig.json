{
  "extends": "@aspect/tsconfig/react.json",
  "compilerOptions": {
    "noEmit": true,
    "incremental": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": false,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", ".next"]
}
