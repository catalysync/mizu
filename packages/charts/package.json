{
  "name": "@aspect/charts",
  "version": "0.1.0",
  "description": "Chart components for the mizu design system (recharts-based)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup && node scripts/prepend-use-client.mjs",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@aspect/css": ">=0.2.0",
    "@aspect/react": ">=0.2.0",
    "@aspect/tokens": ">=0.2.0",
    "react": ">=18",
    "react-dom": ">=18",
    "recharts": ">=2.12 <3"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@aspect/css": "workspace:^",
    "@aspect/react": "workspace:^",
    "@aspect/tokens": "workspace:^",
    "@aspect/tsconfig": "workspace:^",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^25.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.12.7",
    "tsup": "^8.5.0",
    "typescript": "^5.9.0",
    "vitest": "^3.0.0",
    "vitest-axe": "^0.1.0"
  }
}
