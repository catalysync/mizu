{
  "name": "@tweakmizu/mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol server for tweakmizu. Connects Claude Desktop, Cursor, and Windsurf to the mizu design system substrate.",
  "type": "module",
  "bin": {
    "tweakmizu-mcp": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@aspect/tsconfig": "workspace:^",
    "@types/node": "^25.6.0",
    "typescript": "^5.6.0"
  },
  "keywords": [
    "mcp",
    "tweakmizu",
    "mizu",
    "design-system",
    "claude",
    "cursor"
  ]
}
