{
  "name": "@aspect/css",
  "version": "0.1.0",
  "description": "Framework-agnostic component CSS for the mizu design system",
  "type": "module",
  "style": "./dist/mizu.css",
  "exports": {
    ".": "./dist/mizu.css",
    "./typography": "./dist/typography.css",
    "./components/*": "./dist/components/*.css",
    "./layouts/*": "./dist/layouts/*.css",
    "./shell/*": "./dist/shell/*.css",
    "./themes/*": "./dist/themes/*.css"
  },
  "scripts": {
    "build": "node build.mjs",
    "lint": "stylelint 'src/**/*.css'",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@aspect/tokens": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "@aspect/tokens": {
      "optional": true
    }
  },
  "devDependencies": {
    "@aspect/tokens": "workspace:^",
    "lightningcss": "^1.32.0"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "src"
  ]
}
